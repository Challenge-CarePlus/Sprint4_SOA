  "item": [
    {
      "name": "01 - Login Sucesso (Gera Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code deve ser 200 (Login Sucesso)\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Deve gerar e salvar o Token JWT\", function () {",
              "    var resposta = pm.response.json();",
              "    ",
              "    pm.expect(resposta.tokenJWT).to.not.be.undefined;",
              "    ",
              "    pm.collectionVariables.set(\"jwt_token\", resposta.tokenJWT);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"login\": \"admin\",\r\n  \"senha\": \"admin\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:8080/login",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "login"
          ]
        }
      },
      "response": []
    },
